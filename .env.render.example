# ── Render Environment Variables Template ──────────────────────
# Llena estos valores en el Dashboard de Render para cada servicio.
# ⚠️  JWT_SECRET debe ser EXACTAMENTE EL MISMO en gateway y auth-service

# ── JWT (api-gateway y auth-service → mismo valor exacto) ─────
JWT_SECRET=genera-un-seguro-de-al-menos-32-caracteres

# ── Auth DB ────────────────────────────────────────────────────
# Render te da una "Internal Database URL" como:
#   postgres://authuser:XXXX@host:5432/authdb
# Conviértela a JDBC: cambia "postgres://" por "jdbc:postgresql://"
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/authdb
SPRING_DATASOURCE_USERNAME=authuser
SPRING_DATASOURCE_PASSWORD=<password>

# ── Course DB ──────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/coursedb
SPRING_DATASOURCE_USERNAME=courseuser
SPRING_DATASOURCE_PASSWORD=<password>

# ── Enrollment DB ──────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/enrollmentdb
SPRING_DATASOURCE_USERNAME=enrolluser
SPRING_DATASOURCE_PASSWORD=<password>

# ── AWS S3 (Course Service) ────────────────────────────────────
AWS_ACCESS_KEY_ID=tu-access-key
AWS_SECRET_ACCESS_KEY=tu-secret-key
AWS_S3_BUCKET=edutrack-covers
AWS_REGION=us-east-2

# ═══════════════════════════════════════════════════════════════
# VARIABLES AUTO-PROVISTAS POR RENDER (NO las toques):
#   AUTH_SERVICE_HOST    ← Render la setea automáticamente
#   COURSE_SERVICE_HOST  ← Render la setea automáticamente
#   ENROLLMENT_SERVICE_HOST ← Render la setea automáticamente
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# CONFIGURACIÓN EN VERCEL:
#   Ve a: Vercel Dashboard → tu proyecto → Settings → Environment Variables
#   Agrega:
#     Variable: VITE_API_URL
#     Value:    https://<tu-gateway>.onrender.com
#     (Ej: https://microservicesproject-edutrack-2.onrender.com)
# ═══════════════════════════════════════════════════════════════
