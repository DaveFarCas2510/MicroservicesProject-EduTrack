# ── Render Environment Variables Template ──────────────────────
# Llena estos valores en el Dashboard de Render para cada servicio.

# JWT (mismo valor en api-gateway y auth-service)
JWT_SECRET=genera-un-seguro-de-al-menos-32-caracteres

# Auth DB (Internal Database URL → cambia postgres:// por jdbc:postgresql://)
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/authdb
SPRING_DATASOURCE_USERNAME=authuser
SPRING_DATASOURCE_PASSWORD=<password>

# Course DB
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/coursedb
SPRING_DATASOURCE_USERNAME=courseuser
SPRING_DATASOURCE_PASSWORD=<password>

# Enrollment DB
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/enrollmentdb
SPRING_DATASOURCE_USERNAME=enrolluser
SPRING_DATASOURCE_PASSWORD=<password>

# AWS S3 (Course Service)
AWS_ACCESS_KEY_ID=tu-access-key
AWS_SECRET_ACCESS_KEY=tu-secret-key
AWS_S3_BUCKET=edutrack-covers
AWS_REGION=us-east-2
